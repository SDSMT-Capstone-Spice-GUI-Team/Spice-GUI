QFrame, QLabel, QTooltip {
    background-color: #4f4f4f;
    color: #ededed;
    font-family: "JetBrains Mono";
    border-radius: 6px;
    padding: 5px;
}

QWidget {
    background-color: #2f2f2f;
}

QMainWindow {
    background-color: #2f2f2f;
}

QPushButton {
    font-family: "JetBrains Mono";
    color: #ededed;
    border: 0px;
    border-radius: 6px;
    background-color: #2f2f2f;
}

QPushButton:hover {
    background-color: #B3A369;
}