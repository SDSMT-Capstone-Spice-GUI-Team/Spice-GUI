' ============================================================
' SIMULATION LAYER
' ============================================================
package "simulation" <<Frame>> #FFEBEE {

    class NgspiceRunner {
        + run(netlist, timeout) : tuple[bool, str, str]
        + is_installed() : bool
        + get_version() : str
    }

    class NetlistGenerator {
        + components : dict
        + wires : list
        + nodes : list
        + analysis_type : str
        + analysis_params : dict
        + measurements : list[str]
        --
        + generate() : str
    }

    class ResultParser {
        + parse(raw_output, analysis_type) : dict
        + parse_node_voltages(output) : dict
        + parse_branch_currents(output) : dict
    }

    class PresetManager {
        - _presets : dict
        --
        + save_preset(name, config)
        + load_preset(name) : dict
        + list_presets() : list[str]
    }

    enum ErrorCategory {
        CONVERGENCE
        CIRCUIT_INCOMPLETE
        ZERO_VOLTAGE_SOURCE
        MISSING_GROUND
        SYNTAX_ERROR
        UNKNOWN
    }

    class ErrorDiagnosis <<dataclass>> {
        + category : ErrorCategory
        + severity : str
        + message : str
        + suggestions : list[str]
    }

    class FFTResult <<dataclass>> {
        + frequencies : list[float]
        + magnitudes : list[float]
        + phases : list[float]
        + fundamental_freq : Optional[float]
        + harmonics : dict[int, float]
    }

    SimulationController --> NgspiceRunner : runs
    SimulationController --> NetlistGenerator : generates
    SimulationController --> ResultParser : parses
    SimulationController --> PresetManager
}

' ============================================================
' GRADING LAYER
' ============================================================
package "grading" <<Frame>> #F1F8E9 {

    class Rubric <<dataclass>> {
        + title : str
        + total_points : int
        + checks : list[RubricCheck]
    }

    class RubricCheck <<dataclass>> {
        + check_id : str
        + check_type : str
        + points : int
        + params : dict
        + feedback_pass : str
        + feedback_fail : str
    }

    class CircuitGrader {
        - _comparer : CircuitComparer
        --
        + grade(student, rubric, reference) : GradingResult
    }

    class CircuitComparer {
        + check_component_exists(circuit, id, type) : ComparisonResult
        + check_component_value(circuit, id, value, tol) : ComparisonResult
        + check_topology(student, reference) : ComparisonResult
    }

    class GradingResult <<dataclass>> {
        + student_file : str
        + rubric_title : str
        + total_points : int
        + earned_points : int
        + check_results : list[CheckGradeResult]
        + percentage : float  <<property>>
    }

    class CheckGradeResult <<dataclass>> {
        + check_id : str
        + passed : bool
        + points_earned : int
        + points_possible : int
        + feedback : str
    }

    class BatchGrader {
        + grade_directory(dir, rubric, progress) : BatchGradingResult
    }

    class BatchGradingResult <<dataclass>> {
        + total_files : int
        + successfully_graded : int
        + results : list[GradingResult]
    }

    class CheckAnalytics {
        + analyze_results(results) : dict
        + get_check_pass_rate(check_id) : float
    }

    Rubric *-- "1..*" RubricCheck
    CircuitGrader *-- CircuitComparer
    CircuitGrader --> Rubric : uses
    GradingResult *-- "0..*" CheckGradeResult
    BatchGrader --> CircuitGrader : uses
    BatchGradingResult *-- "0..*" GradingResult
    CheckAnalytics --> GradingResult : analyzes
}

