package "protocols" <<Frame>> #E8F5E9 {

    interface CircuitCanvasProtocol <<Protocol>> {
        + handle_observer_event(event, data)
        + get_selected_component_ids() : list[str]
        + clear_selection()
        + select_components(ids: list[str])
        + zoom_in()
        + zoom_out()
        + zoom_fit()
        + get_zoom_level() : float
        + set_show_component_labels(show: bool)
        + set_show_component_values(show: bool)
        + set_show_node_labels(show: bool)
        + set_node_voltages(voltages: dict)
        + clear_op_annotations()
        + export_image(filepath, include_grid)
        + refresh_theme()
    }

    interface ApplicationShellProtocol <<Protocol>> {
        + circuit_ctrl : CircuitController
        + file_ctrl : FileController
        + simulation_ctrl : SimulationController
        + set_window_title(title: str)
        + show_status_message(msg, timeout)
        + set_dirty(dirty: bool)
    }

    interface DialogProvider <<Protocol>> {
        + ask_save_file(title, filters, default) : Optional[Path]
        + ask_open_file(title, filters) : Optional[Path]
        + confirm(title, message) : bool
        + show_error(title, message)
        + show_warning(title, message)
        + show_info(title, message)
        + ask_analysis_params(...) : Optional[dict]
        + create_progress(title, msg, max) : ProgressHandle
    }

    interface ProgressHandle <<Protocol>> {
        + update(value, message) : bool
        + close()
    }
}

' ============================================================
' CONTROLLERS LAYER
' ============================================================
package "controllers" <<Frame>> #E3F2FD {

    abstract class Command <<ABC>> {
        + {abstract} execute()
        + {abstract} undo()
        + get_description() : str
    }

    class AddComponentCommand { }
    class DeleteComponentCommand { }
    class MoveComponentCommand { }
    class RotateComponentCommand { }
    class FlipComponentCommand { }
    class ChangeValueCommand { }
    class AddWireCommand { }
    class DeleteWireCommand { }
    class ToggleWireLockCommand { }
    class RerouteWireCommand { }
    class PasteCommand { }
    class AddAnnotationCommand { }
    class DeleteAnnotationCommand { }
    class EditAnnotationCommand { }
    class CompoundCommand {
        + commands : list[Command]
        + description : str
    }

    Command <|-- AddComponentCommand
    Command <|-- DeleteComponentCommand
    Command <|-- MoveComponentCommand
    Command <|-- RotateComponentCommand
    Command <|-- FlipComponentCommand
    Command <|-- ChangeValueCommand
    Command <|-- AddWireCommand
    Command <|-- DeleteWireCommand
    Command <|-- ToggleWireLockCommand
    Command <|-- RerouteWireCommand
    Command <|-- PasteCommand
    Command <|-- AddAnnotationCommand
    Command <|-- DeleteAnnotationCommand
    Command <|-- EditAnnotationCommand
    Command <|-- CompoundCommand

    class UndoManager {
        + max_depth : int
        - _undo_stack : list[Command]
        - _redo_stack : list[Command]
        --
        + execute(cmd: Command)
        + undo() : bool
        + redo() : bool
        + can_undo() : bool
        + can_redo() : bool
        + get_undo_description() : Optional[str]
        + clear()
    }

    class CircuitController {
        + model : CircuitModel
        + undo_manager : UndoManager
        - _observers : list[Callable]
        - _clipboard : ClipboardData
        - _locked_components : set[str]
        --
        + add_observer(callback)
        + remove_observer(callback)
        - _notify(event: str, data)
        + add_component(type, position) : ComponentData
        + remove_component(id: str)
        + rotate_component(id, clockwise)
        + flip_component(id, horizontal)
        + update_component_value(id, value)
        + move_component(id, position)
        + add_wire(start_id, start_term, end_id, end_term)
        + remove_wire(index)
        + execute_command(cmd: Command)
        + push_already_executed(cmd: Command)
        + copy_components(ids) : bool
        + paste_components() : tuple
        + get_components() : dict
        + get_wires() : list
        + get_nodes_and_terminal_map() : tuple
        + set_net_name(node, label)
        + rebuild_nodes()
        + to_dict() : dict
    }

    class FileController {
        + model : CircuitModel
        + circuit_ctrl : CircuitController
        + current_file : Optional[Path]
        --
        + new_circuit()
        + save_circuit(filepath)
        + load_circuit(filepath)
        + load_from_dict(data)
        + has_file() : bool
        + get_recent_files() : list[Path]
    }

    class SimulationController {
        + model : CircuitModel
        + circuit_ctrl : CircuitController
        - _runner : Optional[NgspiceRunner]
        --
        + set_analysis(type, params)
        + get_analysis_type() : str
        + validate_circuit() : SimulationResult
        + generate_netlist() : str
        + run_simulation() : SimulationResult
        + cancel_simulation()
    }

    class SimulationResult <<dataclass>> {
        + success : bool
        + analysis_type : str
        + data : Any
        + errors : list[str]
        + warnings : list[str]
        + netlist : str
        + raw_output : str
        + measurements : Optional[dict]
    }

    class TemplateController {
        + template_manager : TemplateManager
        + circuit_ctrl : CircuitController
        + file_ctrl : FileController
        --
        + create_template_from_circuit() : TemplateData
        + load_template(path) : TemplateData
    }

    class TemplateManager {
        + template_dir : Path
        --
        + save_template(template, filepath)
        + load_template(filepath) : TemplateData
        + list_templates() : list[TemplateInfo]
    }

    class SettingsService <<singleton>> {
        + get_value(key, default) : Any
        + set_value(key, value)
        + get_recent_files() : list[str]
    }

    class KeybindingsRegistry {
        - _bindings : dict[str, str]
        --
        + register_binding(action, keys)
        + get_binding(action) : Optional[str]
        + load_bindings()
        + save_bindings()
    }

    class ThemeController {
        + theme_manager : ThemeManager
        --
        + set_theme(name)
        + get_current_theme() : str
        + list_themes() : list[str]
    }

    CircuitController *-- CircuitModel
    CircuitController *-- UndoManager
    CircuitController *-- ClipboardData
    FileController --> CircuitController : uses
    FileController --> CircuitModel : reads
    SimulationController --> CircuitController : uses
    SimulationController --> CircuitModel : reads
    TemplateController --> TemplateManager
    TemplateController --> CircuitController
    UndoManager o-- "0..*" Command
    CompoundCommand o-- "1..*" Command
}

