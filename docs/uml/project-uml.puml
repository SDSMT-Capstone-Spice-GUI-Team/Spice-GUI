package "algorithms" <<Frame>> #FFF3E0 {

    abstract class WeightedPathfinder <<ABC>> {
        + grid_size : int
        + allow_diagonal : bool
        + bend_penalty_base : float
        + crossing_penalty : float
        + body_crossing_penalty : float
        --
        + {abstract} find_path(start, end, obstacles, ...) : tuple
        # _pos_to_grid(pos) : tuple
        # _grid_to_pos(grid) : tuple
    }

    class IDAStarPathfinder {
        + find_path(start, end, obstacles, ...) : tuple
    }

    WeightedPathfinder <|-- IDAStarPathfinder

